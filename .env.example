# Backend (default port 3002)
PORT=3002
# OpenAI API key (required)
OPENAI_API_KEY=sk-...
# Optional: model for translation (default gpt-5-mini). Leave unset or empty to use default.
# OPENAI_MODEL=gpt-5-mini
# Optional: max completion tokens (default 512). Reasoning models need more headroom so output text is not empty.
# OPENAI_MAX_COMPLETION_TOKENS=512

# Commons OAuth token (optional; only required for saving captions to Commons)
COMMONS_OAUTH_TOKEN=

# Frontend (optional; defaults to http://localhost:3002)
NEXT_PUBLIC_API_URL=http://localhost:3002

# Ngrok single-tunnel (docker-compose.ngrok.yml). Use NGROK_AUTHTOKEN (no underscore).
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
